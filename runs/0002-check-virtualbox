#!/usr/env/bin bash
set -x

echo "checking for commands"
command -v systemd-detect-virt >/dev/null 2>&1 || exit
echo "checking for commands"
command -v dmidecode >/dev/null 2>&1 || exit

echo "checking virutalization"

is_virtualbox=false

systemvirt="$(systemd-detect-virt)"

echo "virutualization type=$systemvirt"

if [[ $systemvirt != "oracle" ]]; then
  exit
fi

product_line=$(sudo dmidecode --type system | grep "Product")

if [[ $product_line == *VirtualBox* ]]; then
  is_virtualbox=true
fi

$is_virtualbox || exit

echo "gathering list of disks"

cdroms=$(lsblk | grep rom | awk '{ print $1 }')

for cd in $cdroms; do
  echo "attempting to mount $cd"
  sudo mount "/dev/$cd" /mnt >/dev/null 2>&1 || continue
  echo "mount successful searching for VBoxLinuxAdditions.run /dev/$cd"

  cd_search=$(find /mnt -type f -name "VBoxLinuxAdditions.run")

  if [[ $cd_search != *VBoxLinuxAdditions.run ]]; then
    sudo umount /mnt && continue
  fi
  echo "Found, installing required dependancies"
  sudo apt install gcc make bzip2 linux-headers-$(uname -r) -y
  sudo /bin/bash /mnt/VBoxLinuxAdditions.run
  sudo umount /mnt && echo "unmounted $cd"

done
